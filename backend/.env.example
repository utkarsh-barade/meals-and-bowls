# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

DB_URL=jdbc:mysql://localhost:3306/meals_bowls?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# Generate a strong 256-bit secret: openssl rand -base64 32
JWT_SECRET=change-this-to-a-strong-secret-in-production
JWT_EXPIRY_MS=86400000

CORS_ORIGINS=http://localhost:5173
